# Public model; no Hugging Face token is required when access is unrestricted.
MODEL_PATH=nvidia/Qwen3.6-27B-NVFP4
MODEL_REVISION=0893e1606ff3d5f97a441f405d5fc541a6bdf404
SERVED_MODEL_NAME=qwen3.6-27b-nvfp4
PORT=9952

# Immutable benchmark metadata used to materialize a local scorer dataset.
SWE_DATASET=princeton-nlp/SWE-bench_Verified
SWE_DATASET_REVISION=c104f840cc67f8b6eec6f759ebc8b2693d585d4a

# Override only when using an existing environment outside this repository.
# VLLM_BIN=/absolute/path/to/vllm
# SWE_PYTHON=/absolute/path/to/python
# QWEN_BIN=/absolute/path/to/qwen

# Frozen RTX 5090 profile.
MAX_MODEL_LEN=32768
MAX_NUM_BATCHED_TOKENS=4096
MAX_NUM_SEQS=2
NUM_SPEC_TOKENS=1
GPU_MEMORY_UTILIZATION=auto
KV_CACHE_DTYPE=auto
KV_OFFLOAD_GB=0
ATTENTION_BACKEND=TRITON_ATTN

# Qwen3.6 thinking/agent envelope.
LUMO_ENABLE_THINKING=true
LUMO_PROXY_FORCE_TEMPERATURE=1.0
LUMO_PROXY_FORCE_TOP_P=0.95
LUMO_PROXY_FORCE_TOP_K=20
LUMO_PROXY_FORCE_MIN_P=0.0
LUMO_PROXY_FORCE_PRESENCE_PENALTY=0.0
LUMO_PROXY_FORCE_SEED=880001234
