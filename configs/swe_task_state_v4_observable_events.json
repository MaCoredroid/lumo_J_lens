    },
    "transition_kind": {
      "classes": [
        "continuation",
        "advance",
        "rework"
      ],
      "definition": "visible action transition from completion t-1 to completion t; never skip a request"
    },
    "milestone_within_2": {
      "classes": [
        "none",
        "edit",
        "check"
      ],
      "definition": "first non-inspection action at completion t or immediately following completion t+1"
    },
    "tool_outcome": {
      "classes": [
        "success",
        "failure"
      ],
      "definition": "tool execution result attached to ensuing materialized completion t"
    },
    "validation_outcome": {
      "classes": [
        "success",
        "failure"
      ],
      "definition": "conditional outcome only when ensuing completion t is a validation completion"
    },
    "terminal_event": {
      "classes": [
        "no",
        "yes"
      ],
      "definition": "ensuing completion t is the terminal completion"
    },
    "successful_validation_event": {
      "classes": [
        "no",
        "yes"
      ],
      "definition": "unconditional event over ensuing materialized completion t"
    },
    "failed_validation_event": {
