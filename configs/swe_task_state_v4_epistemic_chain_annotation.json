  "chain_definition": {
    "positive_requires_all_slots": [
      "evidence_observation_E",
      "epistemic_conclusion_H",
      "next_action_A",
      "belief_edge_E_to_H",
      "motivation_edge_H_to_A"
    ],
    "order": "E_before_H_before_A",
    "maximum_intervening_prose_clauses_between_H_and_A": 2,
    "evidence_observation_E": "explicit concrete observation from code, tool or test output already available in completion t, specification or contract, or execution environment",
    "epistemic_conclusion_H": "explicit conclusion about cause, behavior, constraint, or repair implication that is distinct from E",
    "next_action_A": "explicit stated inspection, edit, or validation action motivated by H",
    "belief_edges": [
      "supports",
      "refutes",
      "narrows"
    ],
    "motivation_edge": "motivates",
    "earliest_qualifying_chain_only": true,
    "implicit_or_inferred_mental_state_forbidden": true
  },
  "prefix_novelty": {
    "primary_requires": "H_is_not_explicitly_present_or_semantically_entailed_anywhere_in_complete_visible_prefix_h_t",
