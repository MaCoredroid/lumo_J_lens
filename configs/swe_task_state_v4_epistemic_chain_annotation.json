    "annotator_prompt_or_model_identity_hash_bound": true
  },
  "support_and_agreement_gate_before_fitting": {
    "minimum_novel_positive_chains": 100,
    "minimum_novel_positive_chains_per_repository": 5,
    "minimum_each_belief_edge": 40,
    "minimum_repositories_per_belief_edge": 8,
    "minimum_exact_graph_agreement": 0.75,
    "minimum_kappa": 0.7,
    "fallback_if_edge_support_fails": "collapse_refutes_and_narrows_to_revises_only_if_declared_before_any_model_fit",
    "failure_action": "do_not_fit_high_cardinality_signature_decoder"
  },
  "controls": {
