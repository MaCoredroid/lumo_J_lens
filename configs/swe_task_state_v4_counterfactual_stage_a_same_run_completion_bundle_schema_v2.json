{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/swe-task-state-v4-counterfactual-stage-a-same-run-completion-bundle-v2.schema.json",
  "title": "Stage-A V2 condition-blind exact-256-token completion surface",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "status",
    "runtime_config_sha256",
    "surface_policy",
    "records",
    "stage_b_records_present",
    "condition_key_joined",
    "reserved_validation_access_authorized"
  ],
  "properties": {
    "schema_version": {"const": 2},
    "kind": {"const": "swe_task_state_v4_counterfactual_stage_a_same_run_completion_bundle_v2"},
    "status": {"const": "stage_a_same_run_generation_complete_condition_blind"},
    "runtime_config_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "surface_policy": {"const": "exact_256_token_same_run_completion_only_no_prompt_or_condition_join"},
    "records": {
      "type": "array",
      "minItems": 240,
      "maxItems": 240,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["prompt_id", "completion_status", "completion_text"],
        "properties": {
          "prompt_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "completion_status": {"const": "forced_exact_256_token_window"},
          "completion_text": {"type": "string"}
        }
      }
    },
    "stage_b_records_present": {"const": false},
    "condition_key_joined": {"const": false},
    "reserved_validation_access_authorized": {"const": false}
  }
}
