{
  "schema_version": 1,
  "id": "swe-task-state-v4-counterfactual-visible-state-annotation-v1",
  "status": "prospective_condition_blind_visible_language_annotation_contract_no_completions_no_labels_no_model_runtime",
  "purpose": "prospectively freeze a quote-first annotation interface for observable language and behavior in Stage-A selector-control completions, while keeping visible-language labels distinct from future latent activation readouts and from subjective confidence, doubt, stress, emotion, or private chain-of-thought claims",
