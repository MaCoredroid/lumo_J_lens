{
  "event_contract": {
    "diagnosis": {
      "assistant_text_regexes": [
        "(?i)\\bnow i understand(?: the)? (?:issue|problem)\\b",
        "(?i)\\b(?:root cause|issue|problem) is\\b",
        "(?i)\\b(?:is|was) caused by\\b",
        "(?i)\\bthe fix is to\\b"
      ],
      "must_precede_first_source_edit": true
    },
    "repository_orientation": {
      "algorithm": "successful_nonmutating_repository_read_or_search_v1"
    },
    "source_edit": {
      "algorithm": "successful_path_targeted_mutation_command_v1",
      "command_regexes": [
        "(?im)(?:^|[;&|]\\s*|\\n\\s*)(?:cat|echo|printf)\\b[^\\n]*(?:>>?|\\btee\\b)",
        "(?im)(?:^|[;&|]\\s*|\\n\\s*)tee\\b",
        "(?im)\\bsed\\b[^\\n;|]*\\s-i(?:[.A-Za-z0-9_-]*)?\\b",
        "(?im)\\b(?:apply_patch|git\\s+apply|patch\\s+-p\\d+)\\b",
        "(?im)\\b(?:write_text|write_bytes)\\s*\\(",
        "(?im)\\bopen\\s*\\([^\\n]*,[^\\n]*(?:['\"]w|['\"]a|['\"]x)"
      ],
      "must_reference_oracle_source_path": true,
      "requires_successful_tool_result": true
    },
    "source_read": {
      "algorithm": "successful_nonmutating_read_referencing_oracle_path_and_body_v1",
      "declaration_regex_templates": [
        "(?m)^\\s*(?:async\\s+def|def|class|function|fn|func)\\s+{symbol}\\b",
        "(?m)^\\s*(?:export\\s+)?(?:async\\s+)?(?:function\\s+)?{symbol}\\s*\\([^\\n]*\\)\\s*(?:\\{|:|=>)"
      ]
    },
    "successful_validation": {
      "command_regexes": [
        "(?i)(?:^|[;&|]\\s*|\\s)(?:python(?:3|[0-9.]*)?\\s+)?(?:[^\\s;|]*/)?runtests\\.py\\b",
        "(?i)(?:^|[;&|]\\s*|\\s)(?:python(?:3|[0-9.]*)?\\s+-m\\s+)?(?:pytest|unittest)\\b",
        "(?i)(?:^|[;&|]\\s*|\\s)(?:tox|nox|cargo\\s+test|go\\s+test|npm\\s+(?:run\\s+)?test|pnpm\\s+(?:run\\s+)?test|yarn\\s+test|make\\s+test)\\b"
      ],
      "negative_output_regexes": [
        "(?im)^\\s*(?:FAILED|FAILURES?|ERRORS?)\\b",
        "(?i)\\b[1-9][0-9]*\\s+(?:failed|failures?|errors?)\\b",
        "(?i)\\b0\\s+(?:tests?\\s+)?passed\\b",
        "(?im)^\\s*Ran\\s+0\\s+tests?\\b",
        "(?i)\\b(?:no tests ran|no tests? (?:were )?found|collected 0 items?)\\b",
        "(?i)\\bTraceback \\(most recent call last\\)",
        "(?i)\\b(?:ModuleNotFoundError|ImportError|command not found|No module named)\\b"
      ],
      "positive_output_regexes": [
        "(?ims)\\bRan\\s+[1-9][0-9]*\\s+tests?\\b.*?^\\s*OK\\s*$",
        "(?i)\\b[1-9][0-9]*\\s+passed\\b"
      ],
      "requires_successful_tool_result": true
    }
  },
  "kind": "swe_verified_multistage_probe_protocol",
